{
  "name": "portifolio",
  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "bun run scripts/kill-ports.ts",
    "dev": "concurrently -n \"api,worker,web\" -c \"blue.bold,yellow.bold,magenta.bold\" --kill-others-on-fail \"bun run dev:api\" \"bun run dev:worker\" \"bun run dev:web\"",
    "dev:api": "bun --env-file .env --watch apps/api/src/index.ts",
    "dev:worker": "bun --env-file .env --watch apps/worker/src/index.ts",
    "dev:web": "bun run --env-file .env --filter @portfolio/web dev",
    "db:migrate": "bun --env-file .env run apps/api/src/db/migrate.ts",
    "db:seed": "bun --env-file .env run apps/api/src/db/seed.ts",
    "db:audit:schema": "bun --env-file .env run apps/api/src/db/audit-schema-parity.ts",
    "db:backfill:comments": "bun --env-file .env run apps/api/src/db/backfill-comment-rendered-content.ts",
    "db:studio": "cd apps/api && bunx drizzle-kit studio",
    "db:generate": "cd apps/api && bunx drizzle-kit generate",
    "test:services": "docker compose -f docker-compose.test.yml up -d",
    "lint": "bunx biome ci .",
    "fix": "biome check . --write",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "type-check": "bunx tsc --noEmit -p apps/api/tsconfig.json; bunx tsc --noEmit -p apps/worker/tsconfig.json; bunx tsc --noEmit -p apps/web/tsconfig.json",
    "test": "bun run --filter @portfolio/api test && bun run --filter @portfolio/worker test && bun run --filter @portfolio/web test && bun run --filter @portfolio/shared test",
    "build": "cd apps/api && bun run build && cd ../web && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "concurrently": "^9.2.1",
    "path-to-regexp": "^8.4.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "minimatch": "^10.2.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rollup": "^4.60.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "brace-expansion": ">=5.0.5",
    "dompurify": "^3.4.0",
    "esbuild": "$esbuild",
    "express-rate-limit": "^8.3.0",
    "hono": "^4.12.14",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "minimatch": "$minimatch",
    "picomatch": ">=4.0.4",
    "rollup": "$rollup",
    "undici": "^7.24.5",
    "vite": "^7.3.2"
  }
}

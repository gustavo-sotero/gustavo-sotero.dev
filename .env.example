# =============================================================================
# Portfolio API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are required unless marked as [optional].
#
# LOCAL SETUP:
#   1. Run `docker compose -f docker-compose.dev.yml up -d` to start services
#   2. Copy this file: cp .env.example .env
#   3. Fill in the values below
#   4. Run `bun run db:migrate` to apply migrations
#   5. Run `bun run db:seed` to seed sample data
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection URL
# Dev: uses docker-compose.dev.yml defaults
DATABASE_URL=postgresql://portfolio:portfolio_secret@localhost:5432/portfolio_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL
# Dev: uses docker-compose.dev.yml defaults
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret key for signing JWTs — must be at least 32 characters
# Generate: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Dev callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Your numeric GitHub user ID (find at: https://api.github.com/users/YOUR_USERNAME)
# Only this user will be allowed to log in as admin
ADMIN_GITHUB_ID=12345678

# ── S3-compatible Storage (MinIO for dev, R2/S3 for prod) ────────────────────
# Dev: MinIO running via docker-compose.dev.yml
# After starting MinIO, create a bucket named "portfolio-dev" via the console at http://localhost:9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=portfolio-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_REGION=auto

# Public domain for serving assets (no trailing slash)
# Dev: http://localhost:9000/portfolio-dev
# Prod: https://cdn.yourdomain.com
S3_PUBLIC_DOMAIN=http://localhost:9000/portfolio-dev

# ── Telegram Notifications ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIJKlmNoPQRsTUvwxyz
TELEGRAM_CHAT_ID=987654321

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Use the "Always Pass" test secret key during development:
# Test secret: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ── App URLs ──────────────────────────────────────────────────────────────────
# The frontend origin allowed for CORS
ALLOWED_ORIGIN=http://localhost:3001

# The public API URL (used in CSP, sitemap, RSS)
API_PUBLIC_URL=http://localhost:3000

# ── Frontend (Next.js public env vars) ───────────────────────────────────────
# These are exposed to the browser — do NOT put secrets here.
# They are loaded from this root .env by the Next.js --env-file flag.
# NEXT_PUBLIC_API_URL should match API_PUBLIC_URL above.
NEXT_PUBLIC_API_URL=http://localhost:3000
# Cloudflare Turnstile public site key (different from TURNSTILE_SECRET).
# Dev: use Cloudflare's always-pass test site key.
# Prod: get from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Public S3/MinIO domain for Next.js <Image> remotePatterns.
# Dev: should match S3_PUBLIC_DOMAIN above.
NEXT_PUBLIC_S3_PUBLIC_DOMAIN=http://localhost:9000

# ── Next.js server-side variables ────────────────────────────────────────────
# Secret used by the /api/revalidate route to validate on-demand ISR requests.
# Must be at least 16 characters. Generate: openssl rand -hex 32
REVALIDATE_SECRET=your-revalidate-secret-at-least-16-chars

# [optional] Internal URL of the API used by Next.js SSR when running inside Docker
# (avoids going through the public Traefik hostname on the same Docker network).
# When set, this takes precedence over NEXT_PUBLIC_API_URL for server-side fetches.
# Example: http://api:3000
# API_INTERNAL_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────────────────────
# Salt for hashing IP addresses — at least 16 characters
# Generate: openssl rand -hex 16
IP_HASH_SALT=your-random-16-char-salt-here

# Maximum allowed request body size in bytes (default: 1MB = 1048576)
BODY_SIZE_LIMIT=1048576

# [optional] Set to false to disable the single-process in-memory rate-limit
# fallback when Redis is unavailable. Keep enabled for local development.
# Disable it in multi-replica deployments if you prefer fail-closed 503 behavior.
RATE_LIMIT_LOCAL_FALLBACK=true

# ── Admin ─────────────────────────────────────────────────────────────────────
# [optional] Display name used for admin-authored replies in the public comment
# thread. Defaults to "Admin" when not set.
# ADMIN_DISPLAY_NAME=Admin

# ── Docker Compose dev overrides (used in docker-compose.dev.yml) ─────────────
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio_secret
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret

# ── Production only ───────────────────────────────────────────────────────────
# Domain names for Traefik routing (only needed in docker-compose.yml)
# API_DOMAIN=api.yourdomain.com
# WEB_DOMAIN=yourdomain.com
# POSTGRES_DB=portfolio_prod

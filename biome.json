{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "attributePosition": "auto"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "correctness": {
        "noUnusedVariables": "error"
      },
      "complexity": {
        "useArrowFunction": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "includes": ["apps/web/src/app/globals.css"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/web/src/components/ui/breadcrumb.tsx",
        "apps/web/src/components/ui/button-group.tsx",
        "apps/web/src/components/ui/carousel.tsx",
        "apps/web/src/components/ui/field.tsx",
        "apps/web/src/components/ui/input-group.tsx",
        "apps/web/src/components/ui/input-otp.tsx",
        "apps/web/src/components/ui/item.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off",
            "useFocusableInteractive": "off",
            "useKeyWithClickEvents": "off",
            "useAriaPropsForRole": "off",
            "noRedundantRoles": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/web/src/components/ui/marquee.tsx",
        "apps/web/src/components/ui/slider.tsx",
        "apps/web/src/components/ui/terminal.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.next",
      "!**/drizzle",
      "!**/coverage",
      "!**/*.tsbuildinfo",
      "!**/.turbo",
      "!**/tmp",
      "!**/uploads",
      "!**/modules",
      "!**/apps/web/next-env.d.ts",
      "!biome.temp.json"
    ]
  }
}

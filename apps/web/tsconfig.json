{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // ── Next.js / SWC overrides ───────────────────────────────────────────────
    // module must be "esnext" for the Next.js bundler; base uses "Preserve"
    "module": "esnext",
    // verbatimModuleSyntax is incompatible with SWC's CommonJS transform
    "verbatimModuleSyntax": false,
    // noUncheckedIndexedAccess would require pervasive changes across web code
    "noUncheckedIndexedAccess": false,
    // ── Browser / DOM target ─────────────────────────────────────────────────
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    // ── React / JSX ──────────────────────────────────────────────────────────
    "jsx": "react-jsx",
    // ── Module resolution ────────────────────────────────────────────────────
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    // ── Build ────────────────────────────────────────────────────────────────
    "incremental": true,
    // ── Next.js plugin (powers IDE go-to-definition and type checking) ───────
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../../packages/shared/src/**/*"
  ],
  "exclude": ["node_modules", ".next"]
}

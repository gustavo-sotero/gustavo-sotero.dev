{
  "name": "@portfolio/api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "start": "bun --env-file ../../.env run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "echo 'No build step — Bun runs TS directly'",
    "db:generate": "bunx drizzle-kit generate",
    "db:seed": "bun --env-file ../../.env run src/db/seed.ts",
    "db:migrate": "bun --env-file ../../.env run src/db/migrate.ts",
    "db:audit:schema": "bun --env-file ../../.env run src/db/audit-schema-parity.ts",
    "db:backfill:comments": "bun --env-file ../../.env run src/db/backfill-comment-rendered-content.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@hono/swagger-ui": "^0.5.3",
    "@logtape/file": "^2.0.5",
    "@logtape/hono": "^2.0.5",
    "@logtape/logtape": "^2.0.5",
    "@portfolio/shared": "workspace:*",
    "@shikijs/rehype": "^3.23.0",
    "ai": "^6.0.158",
    "bullmq": "^5.71.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.8",
    "rehype-external-links": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-shiki": "^0.0.9",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^3.23.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "hast": "^1.0.0",
    "hast-util-sanitize": "^5.0.2",
    "mdast": "^3.0.0",
    "unist": "^0.0.1",
    "vitest": "^4.1.2"
  }
}
